{
  "schema_version": "1.0.0",
  "scenario_id": "timer-tick",
  "adapter_config": {"timer_enabled": true},
  "actions": [
    {"kind": "click_control", "control_name": "GameStart"},
    {"kind": "click_control", "control_name": "GameHighScores"},
    {"kind": "click_control", "control_name": "ScoreReturn"},
    {"kind": "wait", "seconds": 0.7},
    {"kind": "observe", "sheet": "game", "address": "C8", "min_value": 3},
    {"kind": "observe", "sheet": "game", "address": "C2", "expect_string": "running"},
    {"kind": "screenshot", "name": "timer-responsive"}
  ]
}
