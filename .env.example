# Open-SWE is the only agent. It requires an explicit model choice before it can
# start a run; workbook and LibreOffice tools remain model-free.
XLSLIBERATOR_OPEN_SWE_SERVICE_TOKEN=local-open-swe-change-before-remote-exposure
XLSLIBERATOR_OPEN_SWE_MODEL=
XLSLIBERATOR_OPEN_SWE_REASONING_EFFORT=medium
XLSLIBERATOR_OPEN_SWE_MAX_OUTPUT_TOKENS=32768
XLSLIBERATOR_OPEN_SWE_OWNER_ID=xlsliberator-web
XLSLIBERATOR_OPEN_SWE_POLL_SECONDS=1
XLSLIBERATOR_OPEN_SWE_REQUEST_TIMEOUT_SECONDS=60
XLSLIBERATOR_OPEN_SWE_JOB_TIMEOUT_SECONDS=3600

# Provider credentials are passed only to the Open-SWE control-plane container.
# Configure only the provider selected by XLSLIBERATOR_OPEN_SWE_MODEL.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
FIREWORKS_API_KEY=

# GitHub Models is opt-in twice and is never a default or fallback.
XLSLIBERATOR_GITHUB_MODELS_ENABLED=0
GITHUB_MODELS_TOKEN=

# Optional Open-SWE tracing.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
