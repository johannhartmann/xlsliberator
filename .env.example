# XLSLiberator core is deterministic and requires no model-provider credential.
# The web app delegates serious migrations to the authenticated Open-SWE API.
XLSLIBERATOR_OPEN_SWE_URL=
XLSLIBERATOR_OPEN_SWE_TOKEN=
XLSLIBERATOR_OPEN_SWE_OWNER_ID=xlsliberator-web
XLSLIBERATOR_OPEN_SWE_POLL_SECONDS=1
XLSLIBERATOR_OPEN_SWE_REQUEST_TIMEOUT_SECONDS=60
XLSLIBERATOR_OPEN_SWE_JOB_TIMEOUT_SECONDS=3600
