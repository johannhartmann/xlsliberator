#!/bin/sh
set -eu

display="${DISPLAY:-:99}"
screen="${XLSLIBERATOR_XVFB_SCREEN:-1280x1024x24}"
runtime_dir="${XDG_RUNTIME_DIR:-/tmp/xlsliberator-runtime}"
export XLSLIBERATOR_XVFB_LOG=/tmp/xvfb.log
export XLSLIBERATOR_OPENBOX_LOG=/tmp/openbox.log
export DISPLAY="$display"
export XDG_RUNTIME_DIR="$runtime_dir"

mkdir -p "$runtime_dir"
chmod 0700 "$runtime_dir"

Xvfb "$display" -screen 0 "$screen" -nolisten tcp -noreset >"$XLSLIBERATOR_XVFB_LOG" 2>&1 &
xvfb_pid=$!

cleanup() {
  kill "$xvfb_pid" 2>/dev/null || true
  if [ -n "${openbox_pid:-}" ]; then
    kill "$openbox_pid" 2>/dev/null || true
  fi
}
trap cleanup EXIT INT TERM

ready=0
attempt=0
while [ "$attempt" -lt 50 ]; do
  if xdpyinfo -display "$display" >/dev/null 2>&1; then
    ready=1
    break
  fi
  attempt=$((attempt + 1))
  sleep 0.1
done
if [ "$ready" -ne 1 ]; then
  echo "Xvfb did not become ready" >&2
  exit 70
fi

openbox >"$XLSLIBERATOR_OPENBOX_LOG" 2>&1 &
openbox_pid=$!

dbus-run-session -- /usr/local/bin/runtime-entrypoint "$@"
